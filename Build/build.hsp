#runtime "hsp3cl"
#include "hspcmp.as"
#packopt name "build"

  // 긮깑긤뫮뤭궻긢귻깒긏긣깏궸댷벍
  chdir "../"

  // 둫롰먠믦
  fname = "main.hsp"
  objname = "obj"

  // 긓깛긬귽깑
  hsc_ini fname
  hsc_objname objname
  hsc_comp 4, 36 // UTF8
  if stat {
    dialog "긓깛긬귽깑궸렪봲궢귏궢궫갃"
    end
  }

  // 긮깑긤
  hsc3_make dir_exe + "\\" + "runtime" + "\\"
  if stat {
    dialog "긮깑긤궸렪봲궢귏궢궫갃"
	end
  }

  // 긮깑긤뒶뿹
  dialog "긮깑긤궕뒶뿹궢귏궢궫갃"
  end
